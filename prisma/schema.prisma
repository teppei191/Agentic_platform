generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  password      String?
  role          String    @default("USER") // ADMIN or USER
  image         String?
  emailVerified DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts      Account[]
  sessions      Session[]
  messages      Message[]
  conversations Conversation[]
  agentAccess   AgentAccess[]
  pinnedAgents  PinnedAgent[]
  createdAgents Agent[]       @relation("AgentCreator")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Agent {
  id            String   @id @default(cuid())
  name          String
  description   String?
  icon          String?
  iconColor     String   @default("#6366f1")
  systemPrompt  String?
  category      String   @default("ORGANIZATION") // SYSTEM, ORGANIZATION, PERSONAL
  status        String   @default("DRAFT") // PUBLISHED, DRAFT, ARCHIVED
  isPublic      Boolean  @default(false)
  apiEndpoint   String?
  modelName     String?
  temperature   Float    @default(0.7)
  maxTokens     Int      @default(2048)
  createdById   String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  createdBy     User?          @relation("AgentCreator", fields: [createdById], references: [id])
  access        AgentAccess[]
  pinnedBy      PinnedAgent[]
  conversations Conversation[]
}

model PinnedAgent {
  id      String @id @default(cuid())
  userId  String
  agentId String

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  agent Agent @relation(fields: [agentId], references: [id], onDelete: Cascade)

  @@unique([userId, agentId])
}

model AgentAccess {
  id      String @id @default(cuid())
  userId  String
  agentId String

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  agent Agent @relation(fields: [agentId], references: [id], onDelete: Cascade)

  @@unique([userId, agentId])
}

model Conversation {
  id        String   @id @default(cuid())
  title     String?
  userId    String
  agentId   String
  starred   Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  agent    Agent     @relation(fields: [agentId], references: [id], onDelete: Cascade)
  messages Message[]
}

model Message {
  id             String   @id @default(cuid())
  content        String
  role           String   // "user" or "assistant"
  conversationId String
  userId         String?
  createdAt      DateTime @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user         User?        @relation(fields: [userId], references: [id])
}
